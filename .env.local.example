# Vercel Postgres (auto-populated when you connect Vercel Postgres in dashboard)
POSTGRES_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (optional - for magic link login)
EMAIL_SERVER=
EMAIL_FROM=

# Cron job protection
CRON_SECRET=

# Admin emails (comma-separated, auto-elevated to admin role on first sign-in)
ADMIN_EMAILS=

# Dev-only fallback login. To enable the Credentials provider on the sign-in
# page, set BOTH AUTH_DEV_MODE=true AND AUTH_DEV_PASSWORD=<shared-secret>.
# Ignored when NODE_ENV=production. Without the password the provider is not
# registered, preventing accidental "anyone can log in" misconfiguration.
AUTH_DEV_MODE=
AUTH_DEV_PASSWORD=

# Twilio (outbound SMS from the case-detail contact panel).
# For Twilio test credentials, TWILIO_FROM_NUMBER=+15005550006 is the magic
# number that always succeeds. Set TWILIO_TEST_MODE=true to force the "TEST
# MODE" banner even when using a live SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TEST_MODE=
