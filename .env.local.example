# Vercel Postgres (auto-populated when you connect Vercel Postgres in dashboard)
POSTGRES_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Email / Magic link (Resend SMTP - resend.com)
# Option A: combined connection string
EMAIL_SERVER=smtp://resend:<YOUR_RESEND_API_KEY>@smtp.resend.com:465
# Option B: individual fields (use these for Vercel env var settings)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=<YOUR_RESEND_API_KEY>
EMAIL_FROM=noreply@oneclickit.xyz

# Cron job protection
CRON_SECRET=

# Admin emails (comma-separated, auto-elevated to admin role on first sign-in)
ADMIN_EMAILS=

# Outbound contact providers (optional — when unset, Send SMS/Email falls
# back to a "not_configured" status log so operators still have an audit
# trail and a follow-up task is auto-scheduled).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
