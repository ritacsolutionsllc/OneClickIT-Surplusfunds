# Vercel Postgres (auto-populated when you connect Vercel Postgres in dashboard)
POSTGRES_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (optional - for magic link login)
EMAIL_SERVER=
EMAIL_FROM=

# Cron job protection
CRON_SECRET=

# Admin emails (comma-separated, auto-elevated to admin role on first sign-in)
ADMIN_EMAILS=

# Outbound SMS via Twilio (all three required to actually send; otherwise
# the /contacts/send endpoint falls back to a dry-run that still writes a
# ContactLog row for the audit trail)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Outbound email via Resend (both required to actually send; same dry-run
# fallback applies)
RESEND_API_KEY=
RESEND_FROM=
