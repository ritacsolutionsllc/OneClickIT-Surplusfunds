generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

model County {
  id            String      @id @default(cuid())
  rank          Int
  name          String
  state         String      @db.VarChar(2)
  population    Int
  listUrl       String?     @map("list_url")
  source        String?
  notes         String?
  rulesText     String?     @map("rules_text") @db.Text
  claimDeadline String?     @map("claim_deadline")
  filingOffice  String?     @map("filing_office")
  officePhone   String?     @map("office_phone")
  officeEmail   String?     @map("office_email")
  officeAddr    String?     @map("office_addr")
  assessorUrl   String?     @map("assessor_url")
  lastScraped   DateTime?   @map("last_scraped")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  fundsLists    FundsList[]
  alerts        Alert[]

  @@unique([name, state])
  @@index([state])
  @@index([population])
  @@map("counties")
}

model FundsList {
  id         String   @id @default(cuid())
  countyId   String   @map("county_id")
  scrapeDate DateTime @default(now()) @map("scrape_date")
  status     String   @default("pending")
  fundsData  Json?    @map("funds_data")
  errorMsg   String?  @map("error_msg")
  createdAt  DateTime @default(now()) @map("created_at")

  county     County   @relation(fields: [countyId], references: [id], onDelete: Cascade)

  @@index([countyId])
  @@index([scrapeDate])
  @@map("funds_lists")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          String    @default("user")
  savedSearches Json?     @map("saved_searches") @default("[]")
  createdAt     DateTime  @default(now()) @map("created_at")

  alerts        Alert[]
  claims        Claim[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Alert {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  countyId  String   @map("county_id")
  minAmount Float?   @map("min_amount")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  county    County   @relation(fields: [countyId], references: [id], onDelete: Cascade)

  @@unique([userId, countyId])
  @@map("alerts")
}

model Claim {
  id          String          @id @default(cuid())
  userId      String?         @map("user_id")
  countyName  String          @map("county_name")
  state       String          @db.VarChar(2)
  ownerName   String          @map("owner_name")
  propertyAddr String?        @map("property_addr")
  parcelId    String?         @map("parcel_id")
  amount      Float?
  status      String          @default("research") // research, contacted, docs_gathering, filed, approved, paid, denied
  priority    String          @default("medium")    // low, medium, high
  notes       String?         @db.Text
  filedDate   DateTime?       @map("filed_date")
  deadlineDate DateTime?      @map("deadline_date")
  paidDate    DateTime?       @map("paid_date")
  paidAmount  Float?          @map("paid_amount")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities  ClaimActivity[]

  @@index([userId])
  @@index([status])
  @@index([state])
  @@map("claims")
}

model ClaimActivity {
  id        String   @id @default(cuid())
  claimId   String   @map("claim_id")
  type      String   // note, status_change, document, contact, filing
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_activities")
}

model UnclaimedProperty {
  id            String   @id @default(cuid())
  state         String   @db.VarChar(2)
  ownerName     String   @map("owner_name")
  propertyType  String   @map("property_type")   // cash, securities, safe_deposit, insurance, wages, utility, other
  reportedAmount Float?  @map("reported_amount")
  holderName    String?  @map("holder_name")      // bank, company, etc. that reported it
  address       String?
  city          String?
  zip           String?
  reportedDate  String?  @map("reported_date")
  sourceUrl     String?  @map("source_url")
  externalId    String?  @map("external_id")      // ID from state portal
  lastScraped   DateTime @default(now()) @map("last_scraped")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([state])
  @@index([ownerName])
  @@index([state, ownerName])
  @@map("unclaimed_properties")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
